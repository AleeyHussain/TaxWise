# Copy this file to .env.local and add your own key.
# The AI assistant uses Groq's OpenAI-compatible chat API.
# If no key is set, the app falls back to the built-in simulated assistant,
# so the project still runs fully without a key.

GROQ_API_KEY=your_groq_api_key_here

# Optional: override the default model.
# GROQ_MODEL=llama-3.3-70b-versatile
